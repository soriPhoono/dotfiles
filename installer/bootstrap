#!/usr/bin/env bash

# Check if the script is run as root, this is bad
if [[ $(whoami) == "root" ]]; then
  echo "Please run this script as a normal user"
  exit 1
fi

cd # Go to home directory

# Update
sudo apt update -y && sudo apt upgrade -y

# Install stow and git
packages=(
  "stow"
  "git"
)

sudo apt install "${packages[@]}"

# Install all relevant features
for entry in $(find ./ -type d); do
  if [[ -f ./$entry/module.sh ]]; then
    source ./$entry/module.sh

    module-$(basename $entry)
  fi
done

# Copy dotfiles for current user using gnu stow
cd ~/.dotfiles
stow .
