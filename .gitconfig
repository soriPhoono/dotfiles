[core]
  pager = delta

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true

  side-by-side = true

  line-numbers = true
  line-numbers-left-format = ""
  line-numbers-right-format = "| "

  hyperlinks = true
  hyperlinks-file-link-format = "vscode://file/{path}:{line}"

[merge]
  conflictStyle = diff3

[diff]
  colorMoved = default

[color]
	ui = true
