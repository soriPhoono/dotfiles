{
  "depends": [],
  "optional_repos": [
    {
      "name": "multilib",
      "bootstrap_commands": [
        "paru -Syu --noconfirm",
        "sudo sed -i 's/#\\[multilib\\]/\\[multilib\\]/' /etc/pacman.conf",
        "sudo sed -i '/\\[multilib\\]/!b;n;cInclude = \\/etc\\/pacman.d\\/mirrorlist' /etc/pacman.conf"
      ],
      "pacman_entry": ""
    },
    {
      "name": "chaotic-aur",
      "bootstrap_commands": [
        "paru -Syu --noconfirm",
        "sudo pacman-key --recv-key 3056513887B78AEB --keyserver keyserver.ubuntu.com",
        "sudo pacman-key --lsign-key 3056513887B78AEB",
        "sudo pacman -U --noconfirm --needed 'https://cdn-mirror.chaotic.cx/chaotic-aur/chaotic-keyring.pkg.tar.zst' 'https://cdn-mirror.chaotic.cx/chaotic-aur/chaotic-mirrorlist.pkg.tar.zst'"
      ],
      "pacman_entry": "[chaotic-aur]\nInclude = /etc/pacman.d/chaotic-mirrorlist"
    }
  ],
  "config_files": [
    {
      "source": "/etc/pacman.conf",
      "backup": "Copy",
      "commands": [
        "sudo sed -i 's/#Color/Color/' /etc/pacman.conf",
        "sudo sed -i 's/#ParallelDownloads = 5/ParallelDownloads = 5/' /etc/pacman.conf"
      ]
    }
  ],
  "packages": [
    {
      "name": "paru",
      "depends": [],
      "conflicts": [],
      "from_archive": false,
      "post_install": [],
      "config_files": [
        {
          "source": "/etc/paru.conf",
          "backup": "Copy",
          "commands": [
            "sudo sed -i 's/#BottomUp/BottomUp/' /etc/paru.conf"
          ]
        }
      ]
    },
    {
      "name": "yadm",
      "depends": [],
      "conflicts": [],
      "from_archive": false,
      "post_install": [],
      "config_files": []
    },
    {
      "name": "asp",
      "depends": [],
