      "post_install": [],
      "config_files": []
    },
    {
      "name": "reflector",
      "depends": [],
      "conflicts": [],
      "from_archive": false,
      "post_install": [],
      "config_files": [
        {
          "source": "/etc/xdg/reflector/reflector.conf",
          "backup": "Move",
          "commands": [
            "echo -e '--save /etc/pacman.d/mirrorlist\n--sort rate\n--protocol https\n--latest 10' | sudo tee -a /etc/xdg/reflector/reflector.conf"
          ]
        }
      ]
    },
    {
      "name": "rsync",
