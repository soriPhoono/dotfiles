#!/bin/bash

# Install dependencies
required_packages=(
    "python"        # For running general script
    "python-pyyaml" # For reading and interpreting module configuration
    "git"           # For installing yadm
    "yadm"          # For installing dotfiles
)

sudo pacman -Syu --noconfirm --needed "${required_packages[@]}"

# Report to user
echo "Dependencies installed"
echo "Running general installation script"

# Run general installation script
python "${HOME}/.config/yadm/installer/general.py"
