#!/bin/bash

# If python is not installed
if [ $(command -v cargo >/dev/null) ]; then
    echo "Python is not installed, installing..."

    # Install python
    sudo -A pacman -S --noconfirm --needed rust
fi

# Ensure yadm is not installed
if [ $(command -v yadm >/dev/null) ]; then
    echo "yadm is not installed, installing..."

    # Install yadm
    sudo -A pacman -S --noconfirm --needed yadm
fi

# Run installer script
cargo run --release
