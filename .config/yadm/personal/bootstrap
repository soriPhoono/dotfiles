#!/bin/bash

# Path:         ~/.config/yadm/personal/bootstrap

MULTILIB=false
for arg in "$@"; do
    case $arg in
    -m | --multilib)
        MULTILIB=true
        ;;
    esac
done

feature_sets=()

i=1
echo "Feature sets for personal packages: "
for source_file in $(find ~/.config/yadm/personal -name "*.sh"); do
    if [ $source_file -ne ~/.config/yadm/personal/bootstrap.sh ]; then
        echo "$i) $(basename $source_file)"
        feature_sets+=($source_file)
        i=$((i + 1))
    fi
done
read -p "Select feature set: " feature_set

for feature_set in $feature_set; do
    if [ $feature_set -gt 0 ] && [ $feature_set -lt ${#feature_sets[@]} ]; then
        source $feature_set
    else
        echo "Invalid feature set"
    fi
done
